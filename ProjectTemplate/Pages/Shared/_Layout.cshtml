<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectTemplate</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectTemplate.styles.css" asp-append-version="true"/>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">ProjectTemplate</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()

        </main>
    </div>
    <hr class="footer-divider"/>

    <footer class="astra-footer">
		<div class="footer-muted">
           <div class="container">
               <div class="row g-4">

                   <!--Brand Column-->
                   <div class="col-12 col-md-4 col-lg-3">
                       <div class="brand-name mb-2">ASTRA'S<span>Closet</span></div>
                       <p class="brand-tagline m-0"> More than merch - a statement.<br>Designed for those who lead.</p>
                   </div>

                   <!--Shop Column-->
                   <div class="col-6 col-md-2 col-lg-2 offset-lg-1">
						<div class="footer-heading">Shop</div>
						<ul>
                            <li> <a href="#">All Products</a></li>
                            <li> <a href="#">T-shirt</a></li>
                            <li> <a href="#">Hoodies</a></li>
                            <li> <a href="#">Tote Bags</a></li>
                            <li> <a href="#">Windbreaker</a></li>
                        </ul>
                   </div> 

                     <!--Customer Care Column-->
                     <div class="col-6 col-md-3 col-lg-3">
                         <div class="footer-heading">Customer Care</div>
                         <ul>
                             <li> <a href="#">Contact Us</a></li>
                             <li> <a href="#">Help Center</a></li>
                             <li> <a href="#">Returns & Exchanges</a></li>
                         </ul>
                     </div>

					<!--About Us Column-->
					<div class="col-6 col-md-3 col-lg-3">
                        <div class="footer-heading">About Us</div>
						<ul>
							<li> <a href="#">Our Story</a></li>
							<li> <a href="#">Size Chart</a></li>
							<li> <a href="#">Reviews</a></li>
                            </ul>
                    </div>
              </div>
           </div>
        </div>

        <hr class="footer-divider">
        
        <div class="footer-bottom py-3">
            <div class="container">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                        <span>&copy; 2026 - Astra's<span class="text-warning">Closet</span> - <a asp-area="" asp-page="/Privacy">Privacy</a></span>
                </div>
            </div>
        </div>


    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>