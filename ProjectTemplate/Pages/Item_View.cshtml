    <div class="product-container">

        <div class="gallery-section">
            <div class="thumbnail-column">
                <img src="images/shirt1.jpg" class="thumb active">
                <img src="images/shirt2.jpg" class="thumb">
                <img src="images/shirt3.jpg" class="thumb">
            </div>
            <div class="main-image">
                <img id="mainImage"
                     src="images/shirt1.jpg"
                     alt="TSHIRT 1">
            </div>
        </div>

        <div class="product-details">
            <span class="stock-tag">
                BACK IN STOCK
            </span>
            <h1>TSHIRT 1</h1>

            <div class="rating">
                ★★★★☆
                <span>31 Reviews</span>
            </div>

            <div class="price">
                ₱380.00
            </div>

            <hr>

            <div class="color-section">
                <label>Color: Black</label>
                <div class="color-options">
                    <button class="color black active"></button>
                    <button class="color white"></button>
                </div>
            </div>

            <div class="size-header">
                <label>Sizes</label>
                <button type="button"
                        class="size-guide-btn"
                        onclick="document.getElementById('sizeDialog').showModal()">
                        Size Guide
                </button>

            </div>

            <div class="size-options">
                <button class="size-btn">S</button>
                <button class="size-btn">M</button>
                <button class="size-btn">L</button>
                <button class="size-btn">XL</button>
                <button class="size-btn">2XL</button>
                <button class="size-btn">3XL</button>
                <button class="size-btn">5XL</button>
            </div>

            <div class="quantity-section">
                <label>Quantity</label>
                <div class="quantity-control">
                    <button id="minus">−</button>
                    <input type="text"
                           id="qty"
                           value="1"
                           readonly>
                    <button id="plus">+</button>
                </div>
            </div>

            <button class="cart-btn">
                ADD TO CART (PRE-ORDER)
            </button>

            <details class="product-collapse">
                <summary>
                    Product Description
                </summary>
                <div class="content">
                    <p>
                        Standard school merch can feel a bit rigid.
                        We engineered the Tamaraw Essential Tee
                        to break that mold.
                    </p>
                    <h4>Product Features</h4>
                    <ul>
                        <li>Premium Heavyweight Fabric</li>
                        <li>Modern Boxy Fit</li>
                        <li>High-Density Minimalist Print</li>
                        <li>Zero-Irritation Tag</li>
                    </ul>
                    <h4>Colorways & Specs</h4>
                    <ul>
                        <li>Deep Matte Black</li>
                        <li>Minimalist Off-White</li>
                        <li>220 GSM Premium Cotton Blend</li>
                    </ul>
                </div>
            </details>
        </div>
    </div>

    <div class="review-summary">
        <div class="review-header">
            <h3>Customer Reviews (25)</h3>
            <a href="#">View All</a>
        </div>
        <div class="review-box">
            <h2>4.50</h2>
            <div class="stars">
                ★★★★☆
            </div>
            <p>Review Policy</p>
        </div>
    </div>

    <dialog id="sizeDialog">
        <div class="modal-header">
            <div>
                <h2>FIND MY SIZE</h2>
                <p>T-Shirt Size Chart</p>
            </div>
            <button class="close-btn"
                    onclick="document.getElementById('sizeDialog').close()">
                    ✕
            </button>
        </div>
        <div class="modal-content">
            <div class="size-image">
                <img src="images/size-guide.png">
            </div>
            <div class="size-info">
                <p>
                    Actual garment measurements above refer
                    to the width with garment lying flat.
                </p>
                <p>
                    Double the garment measurement for
                    Chest/Waist/Bottom to find full circumference.
                </p>
                <table class="size-table">
                    <thead>
                        <tr>
                            <th>Sizes</th>
                            <th>S</th>
                            <th>M</th>
                            <th>L</th>
                            <th>XL</th>
                            <th>2XL</th>
                            <th>3XL</th>
                            <th>5XL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Height</td>
                            <td>25</td>
                            <td>26</td>
                            <td>27</td>
                            <td>28</td>
                            <td>29</td>
                            <td>30</td>
                            <td>32</td>
                        </tr>
                        <tr>
                            <td>Width</td>
                            <td>18</td>
                            <td>19</td>
                            <td>20</td>
                            <td>21</td>
                            <td>22</td>
                            <td>23</td>
                            <td>25</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </dialog>