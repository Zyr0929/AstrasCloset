@page
@model ProjectAstra.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In - Astra's Closet";
}

<div class="login-container">
    <div class="login-card">

        <div class="text-center mb-5">
            <div class="brand-title">
                <span class="astra-text">ASTRA'S</span>
                <span class="closet-box">Closet</span>
            </div>
            <p class="sub-brand-text">Nursing Student Council</p>
            <p class="sub-brand-text">FEU NRMF</p>
        </div>

        <form method="post">

            <div class="mb-4">
                <label for="Astra Email" class="form-label custom-label text-uppercase">Astra Email</label>
                <input type="email" class="form-control custom-input" id="Username" name="Username" placeholder="Enter your FEU Astra Email" required>
            </div>

            <div class="mb-4">
                <label for="Password" class="form-label custom-label text-uppercase">Password</label>
                <div class="input-group">
                    <input type="password" class="form-control custom-input" id="Password" name="Password" placeholder="••••••••" required>
                    <span class="input-group-text eye-icon-btn" id="togglePassword">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                            <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z" />
                            <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z" />
                        </svg>
                    </span>
                </div>
            </div>

            <div class="mt-4 mb-4">
                <button type="submit" class="btn btn-signin w-100">Sign in</button>
            </div>
            <div class="text-center mt-3">
                <a href="/Register" class="forgot-link" style="text-decoration: underline;">Create an Account</a>
            </div>
            <div class="text-center mt-4">
                <a href="/Account/ForgotPassword" class="forgot-link">Forgot your password?</a>
            </div>

        </form>
    </div>
</div>
<div class="modal fade" id="authFailedModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered custom-modal-width">
        <div class="modal-content auth-modal-box text-center p-4">

            <h5 class="auth-modal-title mb-4">Authentication Failed</h5>

            <div class="auth-icon-box mb-4">
                <i class="bi bi-lock auth-lock-icon"></i>
            </div>

            <p class="auth-modal-text mb-4">
                Please try again. The username or password you entered is incorrect. For support, contact the NSC - OFFICE.
            </p>

            <button type="button" class="btn btn-signin w-100" data-bs-dismiss="modal">Try Again</button>

        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // This initializes and shows the Bootstrap modal automatically
            var authModal = new bootstrap.Modal(document.getElementById('authFailedModal'));
            authModal.show();
        });
    </script>
}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const togglePassword = document.querySelector("#togglePassword");
        const passwordInput = document.querySelector("#Password");

        togglePassword.addEventListener("click", function () {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);
        });
    });
</script>
