@page
@model ProjectAstra.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Create New Password";
}

<div class="container py-5" style="font-family: 'Inter', sans-serif; max-width: 500px;">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-dark tracking-wide mb-2">Create New Password</h2>
        <p class="text-muted">Please enter your new secure password below.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-0 p-4" style="border: 1px solid #eee !important;">
        <form method="post">
            <input type="hidden" asp-for="Input.Email" />
            <input type="hidden" asp-for="Input.Token" />

            <div asp-validation-summary="ModelOnly" class="text-danger small fw-bold mb-3"></div>

            <div class="mb-4">
                <label asp-for="Input.NewPassword" class="form-label text-uppercase small fw-bold text-muted tracking-wider">New Password</label>
                <input asp-for="Input.NewPassword" class="form-control py-3 rounded-0 border-secondary" type="password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label text-uppercase small fw-bold text-muted tracking-wider">Confirm New Password</label>
                <input asp-for="Input.ConfirmPassword" class="form-control py-3 rounded-0 border-secondary" type="password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn w-100 py-3 fw-bold text-uppercase tracking-wider text-white" style="background-color: #D6A019;">
                Confirm & Reset
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}