@page
@model ProjectAstra.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container py-5" style="font-family: 'Inter', sans-serif; max-width: 500px;">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-dark tracking-wide mb-2">Reset Password</h2>
        <p class="text-muted">Enter your Astra email and we'll send you a link to get back into your account.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success shadow-sm border-0" role="alert" style="background-color: #d1e7dd; color: #0f5132;">
            <i class="bi bi-info-circle-fill me-2"></i> @Model.StatusMessage
        </div>
    }

    <div class="card border-0 shadow-sm rounded-0 p-4" style="border: 1px solid #eee !important;">
        <form method="post">
            <div class="mb-4">
                <label asp-for="Email" class="form-label text-uppercase small fw-bold text-muted tracking-wider">Astra Email Address</label>
                <input asp-for="Email" class="form-control py-3 rounded-0 border-secondary" placeholder="student@astra.edu.ph" />
                <span asp-validation-for="Email" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn w-100 py-3 fw-bold text-uppercase tracking-wider text-white" style="background-color: #0D4F4E;">
                Send Reset Link
            </button>

            <div class="text-center mt-4">
                <a href="/Login" class="text-muted small text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i> Back to Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}