@page
@model ProjectAstra.Pages.Admin.AdminWishlistModel
@{
    ViewData["Title"] = "Wishlist Demand";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4 py-5">
    <h2 class="fw-bold mb-1 text-dark">Wishlist Demand</h2>
    <p class="text-muted mb-4">Anonymous aggregation of highly desired items.</p>

    <div class="card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">PRODUCT</th>
                    <th>CATEGORY</th>
                    <th>PRICE</th>
                    <th class="text-center">TOTAL WISHES</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.TopWishlist)
                {
                    <tr>
                        <td class="ps-4 fw-bold">
                            <img src="@(item.Product.Variations.FirstOrDefault()?.FrontImage ?? "/images/placeholder.png")" style="width: 40px; height: 40px; object-fit: cover;" class="rounded me-2 shadow-sm" />
                            @item.Product.Name
                        </td>
                        <td>@item.Product.Category</td>
                        <td class="fw-bold">₱@item.Product.Price.ToString("F2")</td>
                        <td class="text-center">
                            <span class="badge bg-danger rounded-pill fs-6 px-3 py-2"><i class="bi bi-heart-fill me-1"></i> @item.TotalWishes</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>