@page "/Store/ProductDetail/{id:int}"
@model ProjectAstra.Pages.ProductDetailModel
@inject ProjectAstra.Models.AppDbContext DbContext
@{
    ViewData["Title"] = Model.Product.Name + " - Details";

    var storeSetting = DbContext.StoreSettings.FirstOrDefault();
    bool isPreorderActive = storeSetting == null || storeSetting.CurrentPhase == "Preorder";

    string GetHexColor(string colorName)
    {
        return colorName.ToLower().Trim() switch
        {
            "black" => "#000000",
            "teal" => "#0D4F4E",
            "white" => "#FFFFFF",
            "off-white" => "#F8F9FA",
            "gold" => "#D6A019",
            "red" => "#dc3545",
            "green" => "#28a745",
            "blue" => "#0d6efd",
            _ => colorName
        };
    }

    string GetImg(string path, string viewType)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return $"https://placehold.co/400x500/eeeeee/999999?text=No+{viewType}+Image";
        }
        return path;
    }
}

<style>
    input[name="SelectedColor"]:checked + .color-dot-selection {
        border: 3px solid #0D4F4E !important;
        box-shadow: 0 0 0 2px #ffffff inset;
        transform: scale(1.1);
    }

    .color-dot-selection {
        transition: all 0.2s ease-in-out;
    }

    .main-image-render-box {
        min-height: 450px;
        background-color: #f8f9fa;
        position: relative;
        overflow: hidden;
    }

    .main-frame-group {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .main-preview-display {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
</style>

<div class="container my-5 text-dark dynamic-detail-wrapper" style="font-family: 'Inter', sans-serif;">
    <div class="mb-4">
        <a asp-page="/Store" class="text-dark text-decoration-none fw-bold small tracking-wider back-closet-btn">
            <i class="bi bi-arrow-left"></i> BACK TO THE CLOSET
        </a>
    </div>

    <form method="post">
        <div class="row modern-product-grid">

            <div class="col-12 col-md-6 media-area">
                <div class="product-detail-media-container d-flex gap-3">

                    <div class="thumbnail-selection-column">
                        @for (int i = 0; i < Model.Product.Variations.Count; i++)
                        {
                            var variation = Model.Product.Variations[i];
                            <div class="color-thumb-wrapper color-thumb-grp-@i @(i == 0 ? "" : "d-none")">
                                <div class="thumb-strip-group d-flex flex-column gap-3">
                                    <div class="thumb-card active" onclick="switchDetailPreview(this, 'front-@i')">
                                        <img src="@GetImg(variation.FrontImage, "Front")" alt="Front Thumb" style="width: 100%; object-fit: cover;" />
                                    </div>
                                    <div class="thumb-card" onclick="switchDetailPreview(this, 'back-@i')">
                                        <img src="@GetImg(variation.BackImage, "Back")" alt="Back Thumb" style="width: 100%; object-fit: cover;" />
                                    </div>
                                    <div class="thumb-card" onclick="switchDetailPreview(this, 'extra-@i')">
                                        <img src="@GetImg(variation.ExtraImage, "Extra")" alt="Extra Thumb" style="width: 100%; object-fit: cover;" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="main-image-render-box flex-grow-1 rounded border">
                        @for (int i = 0; i < Model.Product.Variations.Count; i++)
                        {
                            var variation = Model.Product.Variations[i];
                            <div class="main-frame-group image-group-idx-@i @(i == 0 ? "" : "d-none")">
                                <img src="@GetImg(variation.FrontImage, "Front")" class="img-fluid main-preview-display active-view-front-@i" alt="Front Preview" />
                                <img src="@GetImg(variation.BackImage, "Back")" class="img-fluid main-preview-display d-none active-view-back-@i" alt="Back Preview" />
                                <img src="@GetImg(variation.ExtraImage, "Extra")" class="img-fluid main-preview-display d-none active-view-extra-@i" alt="Extra Preview" />
                            </div>
                        }
                    </div>

                </div>
            </div>

            <div class="col-12 col-md-6 info-area">
                <div class="sticky-right-panel ps-md-4">
                    <div class="product-info-panel">
                        @if (!string.IsNullOrEmpty(Model.Product.Tag))
                        {
                            <span class="product-tag-badge d-inline-block rounded-pill mb-2">@Model.Product.Tag</span>
                        }

                        <h1 class="fw-bold text-dark tracking-wide display-6 mb-2 text-uppercase">@Model.Product.Name</h1>

                        <div class="d-flex align-items-center mb-4">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <i class="bi bi-star-fill @(s <= Math.Floor(Model.Product.Rating) ? "star-rating-gold" : "text-secondary opacity-25") me-1"></i>
                            }
                            <span class="text-muted ms-2 small"> snapshot (@Model.Product.ReviewCount Reviews)</span>
                        </div>

                        <div class="fs-2 fw-bold text-dark mb-4 price-tag-display">
                            ₱@Model.Product.Price.ToString("F2")
                        </div>

                        <hr class="border-dark opacity-25 mb-4" />

                        <div class="mb-4">
                            <label class="text-uppercase tracking-wider small fw-bold text-muted mb-2 d-block">Available Colors</label>
                            <div class="d-flex gap-3 align-items-center spec-dot-field">
                                @for (int i = 0; i < Model.Product.Variations.Count; i++)
                                {
                                    string hexColor = GetHexColor(Model.Product.Variations[i].ColorName);

                                    <input type="radio"
                                           name="SelectedColor"
                                           id="detail-color-idx-@i"
                                           value="@Model.Product.Variations[i].ColorName"
                                           class="d-none"
                                           onchange="switchColorGallery(@i)"
                                           @(i == 0 ? "checked" : "") />

                                    <label for="detail-color-idx-@i"
                                           class="color-dot-selection d-inline-block rounded-circle"
                                           style="width: 35px; height: 35px; background-color: @hexColor; border: 1px solid #ccc; cursor: pointer;"></label>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="text-uppercase tracking-wider small fw-bold text-muted m-0">Choose Size</label>
                                <a href="#sizeGuideModal" data-bs-toggle="modal" class="text-dark text-decoration-underline small size-guide-trigger-link">Size Guide</a>
                            </div>
                            <div class="d-flex gap-2 spec-size-field">
                                @foreach (var size in Model.Product.AvailableSizes)
                                {
                                    <input type="radio" name="SelectedSize" id="size-@size" value="@size" class="btn-check" required />
                                    <label for="size-@size" class="btn custom-size-btn">@size</label>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="text-uppercase tracking-wider small fw-bold text-muted mb-2 d-block">Quantity</label>
                            <select name="Quantity" class="form-select custom-bw-dropdown" style="max-width: 120px;">
                                @for (int qty = 1; qty <= Model.Product.MaximumPurchaseLimit; qty++)
                                {
                                    <option value="@qty">@qty</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 action-button-frame">
                        @if (isPreorderActive)
                        {
                            <button type="submit" class="btn flex-grow-1 py-3 fw-bold text-uppercase rounded-0 tracking-wider btn-preorder-submit">
                                Pre-Order Now <i class="bi bi-bag-plus-fill ms-2"></i>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn flex-grow-1 py-3 fw-bold text-uppercase rounded-0 tracking-wider text-white" style="background-color: #6c757d; border: none; cursor: not-allowed;" disabled>
                                Pre-Orders Closed <i class="bi bi-lock-fill ms-2"></i>
                            </button>
                        }

                        <button type="submit" asp-page-handler="AddToWishlist" class="btn py-3 px-4 rounded-0" style="background-color: #f8f9fa; border: 1px solid #ccc; color: #dc3545; transition: all 0.2s ease;" title="Save to Wishlist" onmouseover="this.style.backgroundColor='#ffeeba'" onmouseout="this.style.backgroundColor='#f8f9fa'">
                            <i class="bi bi-heart-fill fs-5"></i>
                        </button>
                    </div>

                    <details class="product-description-accordion mt-4">
                        <summary class="d-flex justify-content-between align-items-center fw-bold text-uppercase tracking-wider py-3">
                            Product Description
                            <i class="bi bi-chevron-down accordion-arrow-indicator"></i>
                        </summary>
                        <div class="accordion-details-content py-2 text-muted">
                            <p style="white-space: pre-line; font-size: 0.95rem; line-height: 1.6;">@Model.Product.Description</p>
                        </div>
                    </details>
                </div>
            </div>

            <div class="col-12 col-md-6 reviews-area">
                <div class="customer-reviews-block mt-md-4 pt-2">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="fw-bold text-dark m-0 text-uppercase h6 tracking-wide">Customer Reviews (@Model.Product.ReviewCount)</h3>
                        <a href="#" class="text-muted text-decoration-none small fw-semibold hover-opacity-100">View All <i class="bi bi-chevron-right small"></i></a>
                    </div>

                    <div class="p-4 mb-4 d-flex flex-column align-items-start" style="background-color: rgba(175, 175, 175, 0.21); border: 0.50px solid #121212;">
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <span class="display-5 fw-bold text-dark m-0" style="line-height: 1;">@Model.Product.Rating.ToString("F2")</span>
                            <div class="d-flex">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi bi-star-fill fs-4 @(s <= Math.Floor(Model.Product.Rating) ? "star-rating-gold" : "text-secondary opacity-25") me-1"></i>
                                }
                            </div>
                        </div>
                        <div class="text-muted small d-flex align-items-center gap-1 mt-1">
                            <span class="text-decoration-underline text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Review Policy</span>
                            <i class="bi bi-question-circle small text-dark"></i>
                        </div>
                    </div>

                    <div class="reviews-feed-stack d-flex flex-column gap-4 mt-4">
                        @if (Model.Product.Reviews != null && Model.Product.Reviews.Any())
                        {
                            @foreach (var review in Model.Product.Reviews)
                            {
                                <div class="row g-3 py-1 border-bottom pb-3">
                                    <div class="col-4 col-sm-3 d-flex flex-column align-items-start">
                                        <div class="d-flex mb-2">
                                            @for (int s = 1; s <= 5; s++)
                                            {
                                                <i class="bi bi-star-fill @(s <= review.RatingScore ? "star-rating-gold" : "text-secondary opacity-25")" style="font-size: 0.75rem; margin-right: 2px;"></i>
                                            }
                                        </div>
                                        <span class="fw-bold text-dark mb-2" style="font-size: 0.95rem;">@review.ReviewerName</span>
                                        <span class="text-uppercase fw-bold border border-dark border-opacity-50 px-2 py-1 rounded-0" style="font-size: 0.6rem; color: #121212; background-color: rgba(0,0,0,0.03); letter-spacing: 0.3px;">Verified</span>
                                    </div>
                                    <div class="col-8 col-sm-9 ps-md-4">
                                        @if (!string.IsNullOrEmpty(review.ReviewBodyText))
                                        {
                                            <p class="text-dark mb-2" style="font-size: 0.95rem; line-height: 1.5; font-weight: 400;">@review.ReviewBodyText</p>
                                        }
                                        <div class="text-muted small mt-1" style="font-size: 0.82rem;">
                                            <span class="fw-bold text-dark">Variant:</span> @review.SelectedSize / @review.SelectedColor
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    function switchDetailPreview(thumbnailElement, codeSignature) {
        const rootContainer = thumbnailElement.closest('.modern-product-grid');

        thumbnailElement.parentElement.querySelectorAll('.thumb-card').forEach(card => card.classList.remove('active'));
        thumbnailElement.classList.add('active');

        const targetImageClass = '.active-view-' + codeSignature;
        rootContainer.querySelectorAll('.main-preview-display').forEach(img => img.classList.add('d-none'));

        const activeTargetDisplay = rootContainer.querySelector(targetImageClass);
        if(activeTargetDisplay) {
            activeTargetDisplay.classList.remove('d-none');
        }
    }

    function switchColorGallery(colorIndex) {
        document.querySelectorAll('.color-thumb-wrapper').forEach(el => el.classList.add('d-none'));
        document.querySelectorAll('.main-frame-group').forEach(el => el.classList.add('d-none'));

        document.querySelector('.color-thumb-grp-' + colorIndex).classList.remove('d-none');
        document.querySelector('.image-group-idx-' + colorIndex).classList.remove('d-none');

        const firstThumb = document.querySelector('.color-thumb-grp-' + colorIndex + ' .thumb-card');
        if (firstThumb) {
            firstThumb.click();
        }
    }
</script>