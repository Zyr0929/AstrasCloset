@page
@model ProjectAstra.Pages.PaymentSuccessModel

@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container checkout-wrapper py-5">

    <div class="row g-5 align-items-start">

        <!-- LEFT SIDE -->
        <div class="col-lg-6">

            <!-- Progress -->
            <div class="checkout-progress mb-5">
                <div class="progress">
                    <div class="progress-bar bg-success"
                         style="width:100%">
                    </div>
                </div>
            </div>

            <h1 class="fw-bold text-center mb-3">
                Payment Successful
            </h1>

            <hr class="mb-4" />

            <p class="success-description text-center mb-5">
                You will receive an in-app notification and email
                when your order is available for pickup at the campus.
            </p>

            <!-- INVOICE PREVIEW SUCCESS CONTAINER -->
            <div class="invoice-preview-success-container">

                <div class="invoice-preview-success-header">
                    ASTRA'S Closet
                </div>

                <div class="invoice-preview-success-body">

                    <div class="success-status-icon">
                        ✓
                    </div>

                    <h4 class="fw-bold mb-2">
                        Payment Confirmed
                    </h4>

                    <p class="text-muted mb-4">
                        Your order has been successfully paid and recorded.
                    </p>

                    <div class="success-detail-row">
                        <span class="success-detail-label">
                            Order Reference
                        </span>

                        <span class="success-detail-value">
                            @Model.OrderId
                        </span>
                    </div>

                    <div class="success-detail-row">
                        <span class="success-detail-label">
                            Customer
                        </span>

                        <span class="success-detail-value">
                            @Model.Order?.CustomerName
                        </span>
                    </div>

                    <div class="success-detail-row">
                        <span class="success-detail-label">
                            Year & Section
                        </span>

                        <span class="success-detail-value">
                            @Model.Order?.YearSection
                        </span>
                    </div>

                    <div class="success-detail-row">
                        <span class="success-detail-label">
                            Date Submitted
                        </span>

                        <span class="success-detail-value">
                            @Model.Order?.OrderDate.ToString("MMM dd, yyyy")
                        </span>
                    </div>

                    <div class="success-detail-row">
                        <span class="success-detail-label">
                            Time Submitted
                        </span>

                        <span class="success-detail-value">
                            @Model.Order?.OrderDate.ToString("hh:mm tt")
                        </span>
                    </div>

                    <div class="success-detail-row border-0">
                        <span class="success-detail-label">
                            Payment Status
                        </span>

                        <span class="badge bg-success px-3 py-2">
                            SETTLED
                        </span>
                    </div>

                </div>

            </div>

            <div class="d-flex gap-3 justify-content-center mt-5">

                <a asp-page="/MyOrders"
                   class="btn btn-warning px-5 py-3 fw-semibold">
                    View My Orders
                </a>

                <a asp-page="/Index"
                   class="btn btn-outline-secondary px-5 py-3 fw-semibold">
                    Back To Home
                </a>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-6 checkout-right-panel">

            <div class="checkout-summary-sticky">

                <!-- SAMPLE PRODUCTS FOR NOW ad nalang tables ni ed -->

                <div class="d-flex mb-4">

                    <div class="position-relative me-3">

                        <div class="border shadow-sm"
                             style="
                                width:80px;
                                height:80px;
                                overflow:hidden;">

                            <img src="/images/sample-shirt.png"
                                 class="checkout-thumb" />

                        </div>

                        <span class="
                            position-absolute
                            top-0
                            start-100
                            translate-middle
                            badge
                            rounded-pill
                            bg-warning
                            text-dark">

                            1

                        </span>

                    </div>

                    <div class="flex-grow-1">

                        <div class="fw-semibold">
                            Sample Product
                        </div>

                        <div class="text-muted small">
                            XL / Black
                        </div>

                    </div>

                    <div class="fw-semibold">
                        ₱500.00
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-between mb-4">

                    <span>
                        Subtotal ·
                        @Model.Order?.TotalItems items
                    </span>

                    <span class="fw-semibold">
                        ₱@Model.Order?.TotalPrice.ToString("N2")
                    </span>

                </div>

                <div class="
                    d-flex
                    justify-content-between
                    align-items-center
                    mb-5">

                    <div class="fs-2 fw-bold">
                        Total Paid
                    </div>

                    <div>

                        <small class="text-muted me-1">
                            PHP
                        </small>

                        <span class="fs-1 fw-bold">
                            ₱@Model.Order?.TotalPrice.ToString("N2")
                        </span>

                    </div>

                </div>

                <div class="border border-warning p-4">

                    <div class="d-flex align-items-center">

                        <div class="me-3">

                            <div class="
                                rounded-circle
                                bg-success
                                text-white
                                d-flex
                                justify-content-center
                                align-items-center"
                                 style="
                                    width:60px;
                                    height:60px;
                                    font-size:28px;">

                                ♥

                            </div>

                        </div>

                        <div>

                            Your order helps fund future

                            <strong>
                                Nursing Student Council
                                programs and student initiatives.
                            </strong>

                            Every piece makes a difference.

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>