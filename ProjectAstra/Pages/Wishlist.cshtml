@page
@model ProjectAstra.Pages.WishlistModel
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container my-5" style="font-family: 'Inter', sans-serif; min-height: 60vh;">
    <div class="d-flex justify-content-between align-items-end border-bottom border-2 border-dark pb-3 mb-5">
        <div>
            <h1 class="fw-bold text-dark text-uppercase tracking-wide mb-1 display-6">My Wishlist</h1>
            <p class="text-muted mb-0">Saved items you want to look at later.</p>
        </div>
        <span class="badge bg-dark rounded-pill px-3 py-2 fs-6">@Model.WishlistItems.Count Items</span>
    </div>

    @if (!Model.WishlistItems.Any())
    {
        <div class="text-center py-5 shadow-sm" style="background-color: #f8f9fa; border: 1px dashed #ccc; border-radius: 12px;">
            <i class="bi bi-heart fs-1 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark">Your wishlist is empty</h4>
            <p class="text-muted mb-4">You haven't saved any items yet. Start exploring our collection!</p>
            <a href="/Store" class="btn text-white fw-bold px-5 py-3 text-uppercase tracking-wider" style="background-color: #0D4F4E; border-radius: 0;">Browse Store</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.WishlistItems)
            {
                var firstVariation = item.Product.Variations?.FirstOrDefault();
                string imgUrl = firstVariation != null && !string.IsNullOrWhiteSpace(firstVariation.FrontImage)
                ? firstVariation.FrontImage
                : "https://via.placeholder.com/400x500.png?text=No+Image";

                <div class="col-12 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-0 position-relative" style="background-color: #fff; border: 1px solid #eee !important;">

                        <form method="post" asp-page-handler="Remove" class="position-absolute top-0 end-0 p-2" style="z-index: 10;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Remove from Wishlist">
                                <i class="bi bi-x-lg text-danger"></i>
                            </button>
                        </form>

                        <a href="/Store/ProductDetail/@item.ProductId" class="text-decoration-none text-dark d-flex flex-column h-100">
                            <div class="bg-light" style="aspect-ratio: 4/5; overflow: hidden;">
                                <img src="@imgUrl" class="w-100 h-100" style="object-fit: cover; transition: transform 0.3s ease;" alt="@item.Product.Name" onerror="this.onerror=null;this.src='https://via.placeholder.com/400x500.png?text=Image+Missing';" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                            </div>
                            <div class="card-body p-3 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="fw-bold mb-0 text-truncate pe-2">@item.Product.Name</h6>
                                </div>
                                <div class="fw-bold mb-2" style="color: #121212;">₱@item.Product.Price.ToString("F2")</div>

                                <button type="button" class="btn w-100 fw-bold text-uppercase mt-auto tracking-wider" style="background-color: #D6A019; color: #fff; border-radius: 0; font-size: 0.85rem; padding: 10px;">
                                    View Product
                                </button>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>