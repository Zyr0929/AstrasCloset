@using ProjectAstra.Models
@using Microsoft.EntityFrameworkCore
@inject ProjectAstra.Models.AppDbContext DbContext
@{
    var currentRoute = ViewContext.RouteData.Values["page"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectAstra</title>
    <link class="styles" rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectTemplate.styles.css" asp-append-version="true" />
</head>

<body>

    @{
        // --- CART DATA FETCHING LOGIC ---
        var cartItems = new List<CartItem>();
        int cartItemCount = 0;
        decimal cartSubtotal = 0;

        if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            cartItems = DbContext.CartItems
            .Include(c => c.Product)
            .ThenInclude(p => p.Variations)
            .Where(c => c.Username == User.Identity.Name)
            .ToList();

            cartItemCount = cartItems.Sum(c => c.Quantity);
            cartSubtotal = cartItems.Sum(c => c.UnitPrice * c.Quantity);
        }
        // --- FETCH STORE SETTINGS ---
        var storeSetting = DbContext.StoreSettings.FirstOrDefault();
        if (storeSetting == null)
        {
            storeSetting = new StoreSetting
            {
                CurrentPhase = "Preorder",
                PreorderDeadline = DateTime.Now.AddDays(3)
            };
            DbContext.StoreSettings.Add(storeSetting);
            DbContext.SaveChanges();
        }
    }

    <!--- NAVBAR --->
    <header class="sticky-top shadow-sm" style="z-index: 2020;">
        <nav class="navbar navbar-dark p-0 navbar-custom position-relative" style="background: linear-gradient(to right, #0D4F4E, #1EB580);">
            <div class="container-fluid px-3 px-sm-5 h-100 d-flex align-items-center justify-content-between position-relative">

                <div class="d-flex align-items-center gap-3" style="z-index: 1010;">
                    <button type="button" id="menuToggleBtn" class="text-white bg-transparent border-0 p-0 fs-2 d-flex align-items-center d-lg-none" style="cursor: pointer; min-width: 40px;">
                        <i class="bi bi-list" id="menuToggleIcon"></i>
                    </button>

                    <div class="navbar-brand-wrapper">
                        <a class="navbar-brand m-0 p-0 fs-3 fw-bold" asp-area="" asp-page="/Index" style="font-family: sans-serif; letter-spacing: -0.5px;">
                            <span style="color: #ffffff;">ASTRA'S</span><span style="color: #D6A019; font-family: 'Georgia', serif; font-style: italic; margin-left: 2px;">Closet</span>
                        </a>
                    </div>
                </div>

                <!--- DESKTOP LINKS (GEOMETRIC CENTER FIX) --->
                <div class="d-none d-lg-block position-absolute start-50 translate-middle-x h-100">
                    <ul class="navbar-nav h-100 d-flex flex-row align-items-center gap-4 p-0 m-0">
                        <li class="nav-item"><a class="nav-link custom-nav-link @(currentRoute == "/Index" ? "active" : "")" asp-area="" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link custom-nav-link @(currentRoute == "/Store" ? "active" : "")" asp-area="" asp-page="/Store">Store</a></li>
                        <li class="nav-item"><a class="nav-link custom-nav-link @(currentRoute == "/MyOrders" ? "active" : "")" asp-area="" asp-page="/MyOrders">My Orders</a></li>
                    </ul>
                </div>

                <!--- UTILITY UTILS --->
                <div class="utility-capsule d-flex align-items-center bg-white px-3 py-1 rounded shadow-sm" style="height: 34px; gap: 18px; z-index: 1010;">
                    <a href="javascript:void(0)" id="openSearchBtn" class="text-dark nav-icon-btn d-flex align-items-center">
                        <i class="bi bi-search fs-5"></i>
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="javascript:void(0)" id="openProfileBtn" class="text-dark nav-icon-btn d-flex align-items-center">
                            <i class="bi bi-person-check-fill fs-4" style="color: #1EB580;"></i>
                        </a>
                        <a href="javascript:void(0)" id="openCartBtn" class="text-dark nav-icon-btn cart-btn position-relative d-inline-block">
                            <i class="bi bi-cart3 fs-4"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle d-flex align-items-center justify-content-center"
                                  style="background-color: #D6A019; color: #0D4F4E; font-size: 0.7rem; width: 18px; height: 18px; font-weight: bold; transform: translate(-15%, -25%) !important;">
                                @cartItemCount
                            </span>
                        </a>
                    }
                    else
                    {
                        <a class="text-dark nav-icon-btn d-flex align-items-center @(currentRoute == "/Login" ? "active" : "")" asp-area="" asp-page="/Login">
                            <i class="bi bi-person fs-4"></i>
                        </a>
                        <a href="/Login" class="text-dark nav-icon-btn cart-btn position-relative d-inline-block">
                            <i class="bi bi-cart3 fs-4"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle d-flex align-items-center justify-content-center"
                                  style="background-color: #D6A019; color: #0D4F4E; font-size: 0.7rem; width: 18px; height: 18px; font-weight: bold; transform: translate(-15%, -25%) !important;">
                                0
                            </span>
                        </a>
                    }
                </div>

            </div>
        </nav>

        @if (storeSetting.CurrentPhase == "Preorder")
        {
            <div id="dynamic-countdown-banner" class="countdown-custom d-flex align-items-center justify-content-center w-100"
                 style="background-color: #D6A019; color: #0D4F4E; font-weight: 700; font-size: 1rem;"
                 data-deadline="@storeSetting.PreorderDeadline.ToString("yyyy-MM-ddTHH:mm:ss")">
                Calculating time remaining...
            </div>
        }
        else if (storeSetting.CurrentPhase == "Validation")
        {
            <div class="countdown-custom d-flex align-items-center justify-content-center w-100"
                 style="background-color: #0D4F4E; color: #D6A019; font-weight: 700; font-size: 1rem;">
                <i class="bi bi-shield-lock-fill me-2"></i> Validation Phase: Pre-orders are now closed.
            </div>
        }
        else if (storeSetting.CurrentPhase == "Claiming")
        {
            <div class="countdown-custom d-flex align-items-center justify-content-center w-100"
                 style="background-color: #1EB580; color: #ffffff; font-weight: 700; font-size: 1rem;">
                <i class="bi bi-box2-heart-fill me-2"></i> Claiming Phase is Active: Ready for pickup!
            </div>
        }
    </header>

    <!--- MOBILE MENU NAVIGATION SIDEBAR --->
    <div id="menuOverlay" class="menu-overlay"></div>

    <div id="menuDrawer" class="menu-drawer">
        <div class="p-3 d-flex flex-column gap-2 mt-4 pt-3">
            <a class="sidebar-nav-btn @(currentRoute == "/Index" ? "active" : "")" asp-area="" asp-page="/Index">
                Home <i class="bi bi-arrow-right ms-auto d-inline d-sm-none fs-5 text-muted"></i>
            </a>
            <a class="sidebar-nav-btn @(currentRoute == "/Store" ? "active" : "")" asp-area="" asp-page="/Store">
                Store <i class="bi bi-arrow-right ms-auto d-inline d-sm-none fs-5 text-muted"></i>
            </a>
            <a class="sidebar-nav-btn @(currentRoute == "/MyOrders" ? "active" : "")" asp-area="" asp-page="/MyOrders">
                My Orders <i class="bi bi-arrow-right ms-auto d-inline d-sm-none fs-5 text-muted"></i>
            </a>
        </div>
    </div>

    <div class="container-fluid px-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!--- FOOTER --->
    <hr class="footer-divider" />
    <footer class="astra-footer">
        <div class="footer-muted">
            <div class="container">
                <div class="row g-4">
                    <div class="col-12 col-md-4 col-lg-3">
                        <div class="brand-name mb-2">ASTRA'S<span>Closet</span></div>
                        <p class="brand-tagline m-0"> More than merch - a statement.<br>Designed for those who lead.</p>
                    </div>
                    <div class="col-6 col-md-2 col-lg-2 offset-lg-1">
                        <div class="footer-heading">Shop</div>
                        <ul>
                            <li> <a href="#">All Products</a></li>
                            <li> <a href="#">T-shirt</a></li>
                            <li> <a href="#">Hoodies</a></li>
                            <li> <a href="#">Tote Bags</a></li>
                            <li> <a href="#">Windbreaker</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-3 col-lg-3">
                        <div class="footer-heading">Customer Care</div>
                        <ul>
                            <li> <a href="#">Contact Us</a></li>
                            <li> <a href="#">Help Center</a></li>
                            <li> <a href="#">Returns & Exchanges</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-3 col-lg-3">
                        <div class="footer-heading">About Us</div>
                        <ul>
                            <li> <a href="#">Our Story</a></li>
                            <li> <a href="#">Size Chart</a></li>
                            <li> <a href="#">Reviews</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <hr class="footer-divider">

        <div class="footer-bottom py-3">
            <div class="container">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                    <span>&copy; 2026 - Astra's<span class="text-warning">Closet</span> - <a asp-area="" asp-page="/Privacy">Privacy</a></span>
                </div>
            </div>
        </div>
    </footer>

    <!--- SEARCH COMPONENTS--->
    <div id="searchOverlay" class="search-overlay"></div>
    <div id="searchDrawer" class="search-drawer">
        <div class="d-flex align-items-center justify-content-between px-4 pt-5 pb-3">
            <div class="drawer-search-wrapper d-flex align-items-center flex-grow-1 me-3">
                <i class="bi bi-search text-white fs-5 me-3"></i>
                <input type="text" id="sidebarSearchInput" class="sidebar-search-input" placeholder="browse the closet" autocomplete="off" />
            </div>
            <button type="button" id="closeSearchBtn" class="close-drawer-btn text-white bg-transparent border-0 p-0 d-flex align-items-center">
                <i class="bi bi-x-lg fs-4"></i>
            </button>
        </div>
        <div class="px-5 pt-3">
            <p class="text-muted small text-uppercase tracking-wider" style="font-size: 0.75rem; letter-spacing: 1px;">Popular Searches</p>
            <ul class="list-unstyled text-white-50 small d-flex flex-column gap-2">
                <li><a href="#" class="text-reset text-decoration-none hover-gold">Oversized Hoodies</a></li>
                <li><a href="#" class="text-reset text-decoration-none hover-gold">Cargo Pants</a></li>
                <li><a href="#" class="text-reset text-decoration-none hover-gold">New Arrivals</a></li>
            </ul>
        </div>
    </div>

    <!--- CART COMPONENTS --->
    <div id="cartOverlay" class="search-overlay"></div>
    <div id="cartDrawer" class="search-drawer cart-drawer-bg d-flex flex-column justify-content-between">
        <div class="d-flex flex-column h-100">

            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom-gold">
                <h5 class="text-white m-0 fw-bold fs-5">Your Cart (@cartItemCount)</h5>
                <button type="button" id="closeCartBtn" class="text-white bg-transparent border-0 p-0 d-flex align-items-center opacity-75 hover-opacity-100">
                    <i class="bi bi-x-lg fs-4"></i>
                </button>
            </div>

            <div class="px-4 py-3 border-bottom-gold pre-order-banner d-flex align-items-center justify-content-center gap-3">
                <i class="bi bi-clock text-warning fs-3"></i>
                <div class="text-warning fw-bold tracking-wide text-uppercase small lh-sm text-center">
                    Pre-Order Window<br><span class="fs-6">Closes In 31 Days</span>
                </div>
            </div>

            <div class="flex-grow-1 px-4 py-4" style="overflow-y: auto;">
                @if (cartItems.Any())
                {
                    <div class="d-flex flex-column gap-4">
                        @foreach (var item in cartItems)
                        {
                            var variation = item.Product.Variations.FirstOrDefault(v => v.ColorName == item.SelectedColor) ?? item.Product.Variations.FirstOrDefault();

                            <div class="d-flex align-items-center">
                                <img src="@variation?.FrontImage" style="width: 75px; height: 75px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);" />
                                <div class="ms-3 text-white w-100">
                                    <div class="fw-bold mb-1" style="font-size: 0.95rem;">@item.Product.Name</div>
                                    <div class="text-white-50 small mb-1">Color: @item.SelectedColor | Size: @item.SelectedSize</div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-warning fw-bold">₱@item.UnitPrice.ToString("F2")</span>
                                        <span class="text-white-50 small">Qty: @item.Quantity</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center mt-5 pt-4">
                        <h3 class="fw-black text-warning tracking-wide mb-2" style="font-size: 1.65rem; font-family: sans-serif;">YOUR CART IS EMPTY!</h3>
                        <p class="text-warning opacity-75 fst-italic mb-4" style="font-family: 'Georgia', serif; font-size: 1.1rem;">Shop some of our faves</p>
                        <a href="/Store" class="btn w-100 py-2.5 fw-bold tracking-wider text-uppercase rounded-0" style="background-color: #D6A019; color: #121212;">Start Shopping</a>
                    </div>
                }
            </div>

            @if (cartItems.Any())
            {
                <div class="px-4 py-4" style="background-color: rgba(0,0,0,0.25); border-top: 1px solid rgba(214, 160, 25, 0.3);">
                    <div class="d-flex justify-content-between text-white fw-bold mb-3 fs-5">
                        <span>Subtotal:</span>
                        <span class="text-warning">₱@cartSubtotal.ToString("F2")</span>
                    </div>
                    <a href="/Checkout" class="btn w-100 py-3 fw-bold tracking-wider text-uppercase rounded-0" style="background-color: #D6A019; color: #121212;">
                        Proceed to Checkout
                    </a>
                </div>
            }
        </div>
    </div>

    <!--- PROFILE COMPONENTS --->
    <div id="profileOverlay" class="search-overlay"></div>
    <div id="profileDrawer" class="search-drawer cart-drawer-bg d-flex flex-column justify-content-between">
        <div>
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom-gold">
                <h5 class="text-white m-0 fw-bold fs-5">My Account</h5>
                <button type="button" id="closeProfileBtn" class="text-white bg-transparent border-0 p-0 d-flex align-items-center opacity-75 hover-opacity-100">
                    <i class="bi bi-x-lg fs-4"></i>
                </button>
            </div>
            <div class="px-4 py-5 mt-2 text-center">
                <div class="mb-3">
                    <i class="bi bi-person-circle text-warning" style="font-size: 4rem;"></i>
                </div>
                <h4 class="text-white fw-bold mb-1">Hello, @(User.FindFirst("FirstName")?.Value ?? "Guest")!</h4>

                <div class="mt-5 d-flex flex-column gap-3 px-2">
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin" class="btn btn-outline-warning w-100 fw-bold text-uppercase py-2">Admin Dashboard</a>
                    }
                    <a href="/MyOrders" class="btn btn-outline-light w-100 fw-bold text-uppercase py-2">My Orders</a>
                    <a href="/Wishlist" class="btn btn-outline-light w-100 fw-bold text-uppercase py-2">Wishlist</a>
                    <a href="/ProfileSettings" class="btn btn-outline-light w-100 fw-bold text-uppercase py-2">Settings</a>
                    <hr class="border-secondary my-2" />
                    <a href="/Logout" class="btn btn-danger w-100 fw-bold text-uppercase py-2">Sign Out</a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script type="text/javascript">
        $(document).ready(function () {

            // HAMBURGER MENU DRAWER 
            function openMenu() {
                $('#menuDrawer').addClass('active');
                $('#menuOverlay').addClass('active');
                $('#menuToggleIcon').removeClass('bi-list').addClass('bi-x-lg');
                lockLayoutContext();
            }

            // Global layout lockers
            function lockLayoutContext() {
                $('body').css('overflow', 'hidden');
                var $header = $('header');
                var headerHeight = $header.outerHeight();
                if ($(window).scrollTop() === 0) {
                    $header.next('div').css('padding-top', headerHeight + 'px');
                }
                $header.addClass('fixed-top').removeClass('sticky-top');
            }

            function unlockLayoutContext() {
                $('body').css('overflow', '');
                var $header = $('header');
                $header.addClass('sticky-top').removeClass('fixed-top');
                $header.next('div').css('padding-top', '');
            }

            function closeMenu() {
                $('#menuDrawer').removeClass('active');
                $('#menuOverlay').removeClass('active');
                $('#menuToggleIcon').removeClass('bi-x-lg').addClass('bi-list');
                unlockLayoutContext();
            }

            $('#menuToggleBtn').on('click', function (e) {
                e.preventDefault();
                if ($('#menuDrawer').hasClass('active')) {
                    closeMenu();
                } else {
                    openMenu();
                }
            });

            $('#menuOverlay').on('click', closeMenu);

            $(window).on('resize', function () {
                if ($(window).width() >= 992) {
                    if ($('#menuDrawer').hasClass('active')) {
                        closeMenu();
                    }
                }
            });

            // -- Sidebars popup ( SEARCH, CART, PROFILE) ---
            // Search Drawer
            $('#openSearchBtn').on('click', function (e) {
                e.preventDefault();
                $('#searchOverlay').addClass('active');
                $('#searchDrawer').addClass('active');
                lockLayoutContext();
                setTimeout(function() { $('#sidebarSearchInput').focus(); }, 280);
            });
            function clearSearchContext() {
                $('#searchOverlay').removeClass('active');
                $('#searchDrawer').removeClass('active');
                unlockLayoutContext();
            }
            $('#closeSearchBtn, #searchOverlay').on('click', clearSearchContext);

            // Cart Drawer
            $('#openCartBtn').on('click', function (e) {
                e.preventDefault();
                $('#cartOverlay').addClass('active');
                $('#cartDrawer').addClass('active');
                lockLayoutContext();
            });
            function clearCartContext() {
                $('#cartOverlay').removeClass('active');
                $('#cartDrawer').removeClass('active');
                unlockLayoutContext();
            }
            $('#closeCartBtn, #cartOverlay').on('click', clearCartContext);

            // Profile Drawer
            $('#openProfileBtn').on('click', function (e) {
                e.preventDefault();
                $('#profileOverlay').addClass('active');
                $('#profileDrawer').addClass('active');
                lockLayoutContext();
            });
            function clearProfileContext() {
                $('#profileOverlay').removeClass('active');
                $('#profileDrawer').removeClass('active');
                unlockLayoutContext();
            }
            $('#closeProfileBtn, #profileOverlay').on('click', clearProfileContext);

            // --- GLOBAL ESCAPE KEY ---
            $(document).on('keydown', function (e) {
                if (e.key === 'Escape') {
                    closeMenu();
                    clearSearchContext();
                    clearCartContext();
                    clearProfileContext();
                }
            });

            // --- DEEPLINK HOOK FOR AUTOMATIC CART POPUP ---
            const urlParams = new URLSearchParams(window.location.search);
            if(urlParams.get('openCart') === 'true') {
                $('#openCartBtn').click();
                window.history.replaceState({}, document.title, window.location.pathname);
            }

        });
        // --- LIVE COUNTDOWN TIMER LOGIC ---
            const countdownBanner = document.getElementById('dynamic-countdown-banner');

            if (countdownBanner) {
                const deadlineString = countdownBanner.getAttribute('data-deadline');
                const deadline = new Date(deadlineString).getTime();

                const timerInterval = setInterval(function () {
                    const now = new Date().getTime();
                    const timeRemaining = deadline - now;

                    if (timeRemaining <= 0) {
                        clearInterval(timerInterval);
                        countdownBanner.innerHTML = "Pre-Order Window Has Closed";
                        return;
                    }

                    const days = Math.floor(timeRemaining / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((timeRemaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));

                    countdownBanner.innerHTML = `Pre-Order Closes In ${days}d ${hours}h ${minutes}m`;
                }, 1000); 
            }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>