@model ProjectAstra.Models.ApparelProduct
@{
    string GetHexColor(string colorName)
    {
        return colorName.ToLower().Trim() switch
        {
            "black" => "#000000",
            "teal" => "#0D4F4E",
            "white" => "#FFFFFF",
            "off-white" => "#F8F9FA",
            "gold" => "#D6A019",
            "red" => "#dc3545",
            "green" => "#28a745",
            "blue" => "#0d6efd",
            _ => colorName
        };
    }

    string GetImg(string path, string viewType)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return $"https://via.placeholder.com/400x500.png?text=No+{viewType}";
        }
        return path;
    }
}

<div class="product-card-container">
    @for (int i = 0; i < Model.Variations.Count; i++)
    {
        <input type="radio"
               id="color-idx-@i-@Model.Id"
               name="color-group-@Model.Id"
               class="state-color-toggle color-idx-@i"
               @(i == 0 ? "checked" : "")
               hidden />
    }

    <a href="/Store/ProductDetail/@Model.Id" class="text-decoration-none">
        <div class="card-image-container">
            <div class="image-render-frame">
                @for (int i = 0; i < Model.Variations.Count; i++)
                {
                    var variation = Model.Variations[i];

                    <img src="@GetImg(variation.FrontImage, "Front")"
                         class="img-view view-front color-img-idx-@i"
                         alt="@Model.Name @variation.ColorName Front"
                         onerror="this.onerror=null;this.src='https://via.placeholder.com/400x500.png?text=Image+Missing';" />

                    <img src="@GetImg(variation.BackImage, "Back")"
                         class="img-view view-back color-img-idx-@i"
                         alt="@Model.Name @variation.ColorName Back"
                         onerror="this.onerror=null;this.src='https://via.placeholder.com/400x500.png?text=Image+Missing';" />
                }
            </div>
        </div>
    </a>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <span class="product-tag-badge">@Model.Tag</span>

        <div class="color-selection-row d-flex gap-2">
            @for (int i = 0; i < Model.Variations.Count; i++)
            {
                string hexColor = GetHexColor(Model.Variations[i].ColorName);

                <label for="color-idx-@i-@Model.Id"
                       class="color-dot-selection"
                       style="background-color: @hexColor; width: 20px; height: 20px; display: inline-block; border-radius: 50%; border: 1px solid #ccc; cursor: pointer;">
                </label>
            }
        </div>
    </div>

    <a href="/Store/ProductDetail/@Model.Id" class="text-decoration-none text-reset">
        <h4 class="product-title-text mb-1 hover-gold">@Model.Name</h4>
    </a>

    <div class="d-flex align-items-center mb-1">
        @for (int s = 1; s <= 5; s++)
        {
            <i class="bi bi-star-fill @(s <= Math.Floor(Model.Rating) ? "rating-star-fill text-warning" : "rating-star-empty text-secondary opacity-25") me-1"></i>
        }
        <span class="reviews-count-label">@Model.ReviewCount Reviews</span>
    </div>
    <div class="product-price-label">₱@Model.Price.ToString("F2")</div>
</div>