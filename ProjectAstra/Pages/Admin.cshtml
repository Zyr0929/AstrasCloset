@page
@model ProjectAstra.Pages.AdminModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4 py-5" style="font-family: 'Inter', sans-serif;">

    <div class="mb-5">
        <h2 style="font-weight: 800; color: #121212;">Good Morning, Admin</h2>
        <p style="color: #666;">Here's the summary of your account</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="summary-card p-4 rounded" style="border: 1px solid #eee;">
                <div class="card-title fw-bold text-muted text-uppercase small mb-2">Total Pre-Orders</div>
                <div class="card-value display-6 fw-bold text-dark mb-1">@Model.TotalPreOrders</div>
                <div class="card-subtitle small text-muted">All-time orders</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card p-4 rounded" style="border: 1px solid #eee;">
                <div class="card-title fw-bold text-muted text-uppercase small mb-2">Total Revenue Estimated</div>
                <div class="card-value display-6 fw-bold text-dark mb-1">₱@Model.TotalRevenue.ToString("F2")</div>
                <div class="card-subtitle small text-muted">From verified orders</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card bg-gray p-4 rounded" style="background-color: #f8f9fa; border: 1px solid #eee;">
                <div class="card-title fw-bold text-muted text-uppercase small mb-2">Pending Approval</div>
                <div class="card-value display-6 fw-bold text-dark mb-1">@Model.PendingApproval</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="summary-card p-4 rounded" style="background-color: #fff3cd; border: 1px solid #ffe69c;">
                <div class="card-title fw-bold text-uppercase small mb-2" style="color: #856404;">Under Assessment</div>
                <div class="card-value display-6 fw-bold mb-1" style="color: #856404;">@Model.UnderAssessment</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card p-4 rounded" style="background-color: #d1e7dd; border: 1px solid #badbcc;">
                <div class="card-title fw-bold text-uppercase small mb-2" style="color: #0f5132;">Verified Orders</div>
                <div class="card-value display-6 fw-bold mb-1" style="color: #0f5132;">@Model.VerifiedOrders</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card p-4 rounded" style="background-color: #f8d7da; border: 1px solid #f5c2c7;">
                <div class="card-title fw-bold text-uppercase small mb-2" style="color: #842029;">Rejected Orders</div>
                <div class="card-value display-6 fw-bold mb-1" style="color: #842029;">@Model.RejectedOrders</div>
            </div>
        </div>
    </div>

    <div class="dashboard-table-container bg-white rounded shadow-sm border">
        <div class="table-responsive">
            <table class="table dashboard-table table-hover border-bottom mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="py-3 px-4 small text-muted fw-bold tracking-wider">ORDER ID</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">CUSTOMER NAME</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">YEAR & SECTION</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">TOTAL ITEMS</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">TOTAL PRICE</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">PAYMENT STATUS</th>
                        <th class="py-3 small text-muted fw-bold tracking-wider">DATE ORDERED</th>
                        <th class="py-3 px-4 small text-muted fw-bold tracking-wider text-end">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentOrders.Any())
                    {
                        @foreach (var order in Model.RecentOrders)
                        {
                            string badgeBg = order.PaymentStatus switch
                            {
                                "TO PAY" => "rgba(214, 160, 25, 0.2)",
                                "INCOMPLETE" => "rgba(217, 83, 79, 0.1)",
                                "ASSESSING" => "rgba(13, 79, 78, 0.1)",
                                "VERIFIED" => "rgba(25, 135, 84, 0.1)",
                                "REJECTED" => "rgba(220, 53, 69, 0.1)",
                                _ => "#eee"
                            };
                            string badgeColor = order.PaymentStatus switch
                            {
                                "TO PAY" => "#D6A019",
                                "INCOMPLETE" => "#d9534f",
                                "ASSESSING" => "#0D4F4E",
                                "VERIFIED" => "#198754",
                                "REJECTED" => "#dc3545",
                                _ => "#333"
                            };

                            <tr>
                                <td class="fw-bold px-4" style="color: #0D4F4E;">@order.OrderReference</td>
                                <td class="fw-bold">@order.CustomerName</td>
                                <td>@order.YearSection</td>
                                <td>@order.TotalItems</td>
                                <td class="fw-bold">₱@order.TotalPrice.ToString("F2")</td>
                                <td>
                                    <span class="badge rounded-pill" style="background-color: @badgeBg; color: @badgeColor; border: 1px solid @badgeColor;">
                                        @order.PaymentStatus
                                    </span>
                                </td>
                                <td style="font-weight: 600; color: #666;">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end px-4"><i class="bi bi-three-dots text-muted hover-dark" style="cursor: pointer; font-size: 1.2rem;"></i></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted fst-italic">No orders have been placed yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>