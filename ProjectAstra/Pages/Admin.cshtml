@page
@model ProjectTemplate.Pages.AdminModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="dashboard-wrapper">

        <nav class="sidebar">
            <div class="sidebar-header">
                <h4 style="color: white; font-weight: 800;">ASTRA'S <span style="color: #D6A019; background: #083332; padding: 2px 8px; border-radius: 4px;">Closet</span></h4>
            </div>

            <ul class="sidebar-nav">
                <li><a href="#" class="active"><i class="bi bi-grid-1x2-fill"></i> Overview</a></li>
                <li><a href="#"><i class="bi bi-box-seam"></i> My Orders</a></li>
                <li><a href="#"><i class="bi bi-bell"></i> Notifications</a></li>
                <li><a href="#"><i class="bi bi-heart"></i> Wishlist</a></li>
                <li><a href="#"><i class="bi bi-gear"></i> Settings</a></li>
                <li><a href="#"><i class="bi bi-plus-circle"></i> Add New Product</a></li>
            </ul>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center dropdown">
                    <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://via.placeholder.com/40" class="rounded-circle me-2" alt="Admin">
                        <div>
                            <div style="font-size: 0.85rem; font-weight: 700;">Admin User</div>
                            <div style="font-size: 0.7rem; color: #aaa;">example@gmail.com</div>
                        </div>
                    </a>
                </div>
                <a href="/Logout" style="color: white; font-size: 1.2rem;"><i class="bi bi-box-arrow-right"></i></a>
            </div>
        </nav>

        <main class="main-content">

            <div class="mb-5">
                <h2 style="font-weight: 800; color: #121212;">Good Morning, Admin</h2>
                <p style="color: #666;">Here's the summary of your account</p>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="summary-card">
                        <div class="card-title">Total Pre-Orders</div>
                        <div class="card-value">82</div>
                        <div class="card-subtitle">Since March 2026</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card">
                        <div class="card-title">Total Revenue Estimated</div>
                        <div class="card-value">₱31,1260.00</div>
                        <div class="card-subtitle">Total revenue this quarter</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card bg-gray">
                        <div class="card-title text-muted">Pending Approval</div>
                        <div class="card-value">44</div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="summary-card bg-warning-light">
                        <div class="card-title" style="color: #856404;">Under Assessment</div>
                        <div class="card-value">32</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card bg-success-light">
                        <div class="card-title" style="color: #0f5132;">Verified Orders</div>
                        <div class="card-value">3</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card bg-danger-light">
                        <div class="card-title" style="color: #842029;">Rejected Orders</div>
                        <div class="card-value">6</div>
                    </div>
                </div>
            </div>

            <div class="dashboard-table-container">
                <table class="table dashboard-table table-hover border-bottom mb-0">
                    <thead>
                        <tr>
                            <th>ORDER ID</th>
                            <th>CUSTOMER NAME</th>
                            <th>YEAR & SECTION</th>
                            <th>TOTAL ORDERS</th>
                            <th>TOTAL PRICE</th>
                            <th>PAYMENT STATUS</th>
                            <th>DATE ORDERED</th>
                            <th>ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-bold" style="color: #0D4F4E;">ORD-2026-0101</td>
                            <td class="fw-bold">Jane Doe</td>
                            <td>2-B</td>
                            <td>1</td>
                            <td class="fw-bold">₱380</td>
                            <td><span class="status-badge status-topay">TO PAY</span></td>
                            <td style="color: #1EB580; font-weight: 600;">Mar 25, 2026</td>
                            <td><i class="bi bi-three-dots" style="cursor: pointer; font-size: 1.2rem;"></i></td>
                        </tr>
                        <tr class="tr-incomplete">
                            <td class="fw-bold" style="color: #0D4F4E;">ORD-2026-0101</td>
                            <td class="fw-bold">John Kilometers</td>
                            <td>3-A</td>
                            <td>2</td>
                            <td class="fw-bold">₱760</td>
                            <td><span class="status-badge status-incomplete">INCOMPLETE</span></td>
                            <td style="color: #d9534f; font-weight: 600;">Mar 26, 2026</td>
                            <td><i class="bi bi-three-dots" style="cursor: pointer; font-size: 1.2rem;"></i></td>
                        </tr>
                        <tr class="tr-assessing">
                            <td class="fw-bold" style="color: #0D4F4E;">ORD-2026-0101</td>
                            <td class="fw-bold">Jane Doe</td>
                            <td>2-B</td>
                            <td>1</td>
                            <td class="fw-bold">₱380</td>
                            <td><span class="status-badge status-assessing">ASSESSING</span></td>
                            <td style="color: #1EB580; font-weight: 600;">Mar 28, 2026</td>
                            <td><i class="bi bi-three-dots" style="cursor: pointer; font-size: 1.2rem;"></i></td>
                        </tr>
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center p-3" style="background-color: white; border-top: 1px solid #eee;">
                    <span style="font-size: 0.8rem; color: #888; font-weight: 600; letter-spacing: 0.5px;">SHOWING PAGE 1 OF 17 (82 ORDERS)</span>
                    <div>
                        <button class="btn btn-sm btn-light border me-1"><i class="bi bi-chevron-left"></i></button>
                        <button class="btn btn-sm btn-light border"><i class="bi bi-chevron-right"></i></button>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>